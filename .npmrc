# Prevents npm from running lifecycle scripts (install, postinstall, etc.)
# Protects against supply-chain attacks via malicious package scripts
ignore-scripts=true

# Blocks installation of packages published less than 7 days ago
# Reduces exposure to packages that were published and quickly pulled due to a compromise
min-release-age=7

# Disallows installing packages directly from git URLs
# Prevents bypassing the registry and its security checks
allow-git=none
